//! ZX81 BBS Door Game VOA Display
//! Renders Monster Group VOA in ZX81 character set (64 chars)

use std::fmt;

/// ZX81 character set (inverse video 0x80-0xBF)
const ZX81_CHARS: &[u8] = b" \"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ";

/// Monster Group constants
const MONSTER_ORDER: u64 = 196883;
const J_INVARIANT: u64 = 196884;
const LEECH_DIM: usize = 24;

/// VOA state for BBS door game
#[derive(Debug, Clone)]
pub struct ZX81VOA {
    pub codepoint: u32,
    pub pi71: u8,
    pub pi59: u8,
    pub pi47: u8,
    pub lattice: [i16; LEECH_DIM],
    pub hunger: u8,
    pub score: u32,
    // Vertex Operator Algebra operators
    pub virasoro: [i32; 5],  // L_{-2}, L_{-1}, L_0, L_1, L_2
    pub conformal_weight: f64,
    pub central_charge: f64,
}

impl ZX81VOA {
    pub fn new(codepoint: u32) -> Self {
        let pi71 = (codepoint % 71) as u8;
        let pi59 = (codepoint % 59) as u8;
        let pi47 = (codepoint % 47) as u8;
        
        let mut lattice = [0i16; LEECH_DIM];
        for d in 0..LEECH_DIM {
            lattice[d] = ((codepoint.wrapping_mul(3u32.pow(d as u32))) % 3486784401) as i16 % 256 - 128;
        }
        
        // Virasoro operators from lattice
        let virasoro = [
            lattice[0] as i32 * lattice[1] as i32,  // L_{-2}
            lattice[2] as i32 + lattice[3] as i32,  // L_{-1}
            (pi71 as i32 * pi59 as i32) % 196883,   // L_0 (conformal weight)
            lattice[4] as i32 - lattice[5] as i32,  // L_1
            lattice[6] as i32 * lattice[7] as i32,  // L_2
        ];
        
        let conformal_weight = virasoro[2] as f64 / 196883.0;
        let central_charge = 24.0;  // Monster VOA has c=24
        
