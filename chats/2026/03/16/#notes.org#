import init, { Pad, TripleStore } from './pkg/erdfa_wasm.js';

let pad, triples;
async function setup() {
  await init();
  pad = new Pad();
  triples = new TripleStore();
  window._pad = pad;
  window._triples = triples;
  document.getElementById('cid-out').textContent = '✅ WASM loaded';
}
