window.doStegoEnc = () => {
  const canvas = $('stego-canvas');
  const carrier = $('carrier-preview');
  const w = carrier.naturalWidth || 256, h = carrier.naturalHeight || 256;
  canvas.width = w; canvas.height = h;
  const ctx = canvas.getContext('2d');
  // 1. Draw carrier
  ctx.drawImage(carrier, 0, 0, w, h);
  // 2. Draw meme text onto carrier (becomes part of the image)
  const top = $('meme-top').value.toUpperCase();
  const bot = $('meme-bot').value.toUpperCase();
  const sz = Math.max(16, Math.floor(w / 12));
  ctx.font = `bold ${sz}px Impact, sans-serif`;
  ctx.textAlign = 'center';
  ctx.lineWidth = Math.max(2, sz / 8);
  ctx.strokeStyle = '#000';
  ctx.fillStyle = '#fff';
  if (top) { ctx.strokeText(top, w/2, sz+8); ctx.fillText(top, w/2, sz+8); }
  if (bot) { ctx.strokeText(bot, w/2, h-12); ctx.fillText(bot, w/2, h-12); }
  // 3. Stego encode into the meme (7x ECC redundancy)
  const carrierData = new Uint8Array(ctx.getImageData(0, 0, w, h).data.buffer);
  const pixels = pad.stego_encode(val(), carrierData, w, h);
  const img = new ImageData(new Uint8ClampedArray(pixels), w, h);
  ctx.putImageData(img, 0, 0);
  const cap = Math.floor((Math.floor(w/8) * Math.floor(h/8) * 4) / 7 / 8) - 4;
  if (val().length > cap) {
    set('stego-out', `⚠️ Data too large! ${val().length} bytes > ${cap} byte capacity for ${w}×${h}. Use a larger image.`);
    return;
  }
  set('stego-out', `Encoded ${val().length}/${cap} bytes into ${w}×${h} meme (DCT+7x ECC, survives JPEG)`);
};

