  timestamp=$(echo "$id" | cut -d_ -f1-2 | sed 's/_//')
  
  # Get file size
  size=$(wc -c < "$file")
  
  # Create JSON entry
  jq -n \
    --arg id "$id" \
    --arg title "$title" \
    --arg keywords "$keywords" \
    --arg cid "$cid" \
    --arg witness "$witness" \
    --arg timestamp "$timestamp" \
    --arg filename "$filename" \
    --arg ipfs_cid "$ipfs_cid" \
    --arg size "$size" \
    --arg uucp_path "$file" \
    '{
      id: $id,
      title: $title,
      description: null,
      keywords: ($keywords | split(",") | map(select(length > 0))),
      cid: $cid,
      witness: $witness,
      timestamp: $timestamp,
      filename: $filename,
      ngrams: [],
      ipfs_cid: (if $ipfs_cid == "" then null else $ipfs_cid end),
      reply_to: null,
      size: ($size | tonumber),
      uucp_path: $uucp_path
    }' >> "$INDEX"
done

echo "✅ Reindexing complete!"
echo "Now run: cd /mnt/data1/kant/pastebin/upgrade-cli && ./target/release/upgrade-cli"
EOF
