  # Check if already in index
  if echo "$existing_ids" | grep -q "^$id$"; then
    continue
  fi
  
  echo "Adding: $id"
  
  # Extract header info
  title=$(grep "^Title:" "$file" | cut -d: -f2- | xargs)
  keywords=$(grep "^Keywords:" "$file" | cut -d: -f2- | xargs)
