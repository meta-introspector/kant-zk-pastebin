const val = () => $('input').value;
const set = (id, v) => $(id).textContent = v;

// -- Stop all audio before playing anything new --
let activeCtx = null;
function stopAll() {
  if (activeCtx) try { activeCtx.close(); } catch(e) {}
  activeCtx = null;
  document.querySelectorAll('audio').forEach(a => { a.pause(); a.currentTime = 0; });
  window.speechSynthesis.cancel();
}

window.doCid = () => set('cid-out', pad.cid(val()));
window.doSha = () => set('cid-out', pad.sha256(val()));

window.doMorseEnc = () => set('morse-out', pad.to_morse(val()));
window.doMorseDec = () => $('input').value = pad.from_morse($('morse-out').textContent);
