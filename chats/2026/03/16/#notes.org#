# Get existing IDs
existing_ids=$(cat "$INDEX" 2>/dev/null | jq -r '.id' | sort)

# Find all .txt files
for file in "$SPOOL"/*.txt; do
  [ -f "$file" ] || continue
  
  filename=$(basename "$file")
